{
  "ConnectionStrings": {
    "FlowCore": "Host=localhost;Port=5432;Database=FlowCore;Username=flowcore;Password=flowcore"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistence": {
    "Provider": "PostgreSql",
    "ConnectionStringName": "FlowCore",
    "EnsureCreatedOnStartup": true
  },
  "OfflineSync": {
    "MaxQueueLength": 1000
  },
  "RealtimeSync": {
    "ReconnectDelaySeconds": 3,
    "MaxReconnectDelaySeconds": 30,
    "EnableRestFallback": true
  },
  "Reconciliation": {
    "MaxReplayBatchSize": 100,
    "UseIdempotencyKeys": true
  }
}
